# Copy this file to .env and fill in real values for local development.

WATCHPOINT_SECRET_KEY=change-me

WATCHPOINT_DATABASE_URI=postgresql+psycopg2://watchpoint:password@localhost:5432/watchpoint?sslmode=require
WATCHPOINT_TEST_DATABASE_URI=postgresql+psycopg2://watchpoint:password@localhost:5432/watchpoint_test

WATCHPOINT_WATCHMODE_API_KEY=your-watchmode-api-key
